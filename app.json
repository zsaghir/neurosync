{
  "expo": {
    "name": "clarity.journal",
    "slug": "clarity.journal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clarityjournal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.clarity.journal"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.clarity.journal"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "@clerk/expo",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID": "545739117280-s75nvhsh8fqpafoh1t5u2upbjuer0nvb.apps.googleusercontent.com",
      "EXPO_PUBLIC_CLERK_GOOGLE_IOS_CLIENT_ID": "545739117280-vumgvemjhgulrp4d7436kh0bd4vtt6cq.apps.googleusercontent.com",
      "EXPO_PUBLIC_CLERK_GOOGLE_ANDROID_CLIENT_ID": "545739117280-ua7m5c2kv5cbnufg8b9sl85kucacolnl.apps.googleusercontent.com",
      "EXPO_PUBLIC_CLERK_GOOGLE_IOS_URL_SCHEME": "com.googleusercontent.apps.545739117280-vumgvemjhgulrp4d7436kh0bd4vtt6cq"
    }
  }
}
